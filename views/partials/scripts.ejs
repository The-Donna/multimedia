<script>
    const searchToggle = document.getElementById('searchToggle');
    const searchBox = document.getElementById('searchBox');
    const homepage = document.getElementById('homepage');
    const resultspage = document.getElementById('resultspage');
    const resultscontainer = document.getElementById('results');
    const backButton = document.getElementById('backButton');

    searchToggle.addEventListener('click', () => {
      searchBox.classList.toggle('expanded');
      if (searchBox.classList.contains('expanded')) {
        searchBox.focus();
      }
    });

    searchBox.addEventListener('keydown', async (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        const query = searchBox.value.trim();
        if (!query) return;

        homepage.classList.add('slide-left');
        resultspage.classList.add('active');

        const results = await searchMedia(query);
        displayResults(results);
      }
    });

    backButton.addEventListener('click', () => {
      homepage.classList.remove('slide-left');
      resultspage.classList.remove('active');
      searchBox.value = '';
      resultscontainer.innerHTML = '';
    });

    // Delegated so it still works on dropdowns injected later (e.g. the login-status menu below)
    document.addEventListener('click', function (e) {
      const toggle = e.target.closest('.dropdown-toggle');
      if (toggle) {
        e.preventDefault();
        document.querySelectorAll('.dropdown-menu').forEach(menu => menu.classList.remove('show'));
        const parent = toggle.closest('.dropdown');
        const menu = parent && parent.querySelector('.dropdown-menu');
        if (menu) menu.classList.toggle('show');
      } else {
        document.querySelectorAll('.dropdown-menu').forEach(menu => menu.classList.remove('show'));
      }
    });
</script>

<script src="/js/searchresults.js"></script>

<script>
  fetch('/api/profile')
    .then(res => res.json())
    .then(data => {
      const loginLink = document.getElementById('login-link');
      if (!loginLink || !data.username) return;

      loginLink.innerHTML = `
        <div class="dropdown">
          <a href="#" class="dropdown-toggle" style="color: #F5ECD5; font-weight: bold;">
            Welcome, ${data.username} ▼
          </a>
          <ul class="dropdown-menu">
            <li><a href="/history">History</a></li>
            <li><a href="/favorites">Favorites</a></li>
            <li><a href="/logout">Logout</a></li>
          </ul>
        </div>
      `;
    })
    .catch(err => {
      console.error('Failed to load username:', err);
    });
</script>

